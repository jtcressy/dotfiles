    "defaultMode": "default"
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/jtcressy/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
